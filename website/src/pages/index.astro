---
import foliaIcon from '../assets/folia-icon.png';
import '../styles/site.css';

const base = import.meta.env.BASE_URL;
const repoUrl = 'https://github.com/cat-xierluo/Folia';
const releasesUrl = `${repoUrl}/releases/latest`;

const features = [
  {
    title: '复杂表格稳定阅读',
    text: '保留 HTML table 的 rowspan、colspan 和宽表结构，法律表格、证据目录、材料清单都能安心打开。',
  },
  {
    title: 'Markdown 所见即所得',
    text: '普通 Markdown 默认进入轻量编辑视图，源码模式仍可随时切回，适合阅读、修订和排版前检查。',
  },
  {
    title: 'Word 纸张预览与导出',
    text: '导出前先看到接近 A4 的页面效果，再用内置或自定义 JSON 预设生成 .docx。',
  },
  {
    title: 'HTML 文章与演示预览',
    text: '可复制为公众号编辑器友好的 HTML，也能隔离运行自包含 HTML 演示文件。',
  },
];

const downloadOptions = [
  'macOS Apple Silicon: 选择 aarch64 或 arm64 安装包',
  'macOS Intel: 选择 x64 或 x86_64 安装包',
  'Windows: 选择 .exe 或 .msi 安装包',
];

const workflow = [
  '打开 Markdown、HTML 或拖拽文件进入窗口',
  '阅读复杂表格，必要时切换源码或结构化编辑',
  '打开 Word 或 HTML 预览，确认输出效果',
  '导出 .docx 或复制 HTML 到目标编辑器',
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Folia 是一个面向知识工作者的 Markdown 阅读与 Word 导出工具，稳定处理复杂 HTML 表格，并支持 Word 纸张预览与导出。"
    />
    <meta name="theme-color" content="#f7f1e8" />
    <title>Folia - Markdown 阅读与 Word 导出工具</title>
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="Folia 首页">
        <img src={foliaIcon.src} width="34" height="34" alt="" />
        <span>Folia</span>
      </a>
      <nav class="nav-links" aria-label="主导航">
        <a href="#features">功能</a>
        <a href="#download">下载</a>
        <a href={repoUrl} target="_blank" rel="noreferrer">GitHub</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-product" aria-hidden="true">
          <div class="app-window">
            <div class="app-toolbar">
              <span></span>
              <span></span>
              <span></span>
              <strong>庭审材料目录.md</strong>
            </div>
            <div class="app-body">
              <aside class="app-rail">
                <span></span>
                <span></span>
                <span></span>
              </aside>
              <div class="editor-pane">
                <p class="md-heading"># 证据目录</p>
                <p>## 一、主体资料</p>
                <p>- 营业执照</p>
                <p>- 法定代表人身份证明</p>
                <p>## 二、往来文件</p>
                <p>请核对每份材料的页码、来源和证明目的。</p>
              </div>
              <div class="paper-pane">
                <div class="paper">
                  <h2>证据目录</h2>
                  <table>
                    <thead>
                      <tr>
                        <th>序号</th>
                        <th>材料名称</th>
                        <th>证明目的</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td rowspan="2">1</td>
                        <td>合同及补充协议</td>
                        <td>证明基础交易关系</td>
                      </tr>
                      <tr>
                        <td>付款凭证</td>
                        <td>证明履行情况</td>
                      </tr>
                      <tr>
                        <td>2</td>
                        <td colspan="2">电子邮件、会议纪要与交付记录</td>
                      </tr>
                    </tbody>
                  </table>
                  <blockquote>Folia 会尽量保持表格结构和纸面版式一致。</blockquote>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="hero-content">
          <img class="hero-icon" src={foliaIcon.src} width="86" height="86" alt="" />
          <p class="eyebrow">Markdown reader for demanding documents</p>
          <h1 id="hero-title">Folia</h1>
          <p class="hero-copy">
            面向知识工作者的 Markdown 阅读与 Word 导出工具。打开复杂表格文档，确认纸张版式，再稳定交付给同事、客户或法院系统。
          </p>
          <div class="hero-actions" aria-label="主要操作">
            <a class="button button-primary" href={releasesUrl}>下载最新版</a>
            <a class="button button-secondary" href={repoUrl} target="_blank" rel="noreferrer">查看源码</a>
          </div>
        </div>
      </section>

      <section class="section section-intro" aria-labelledby="intro-title">
        <div class="section-inner intro-grid">
          <div>
            <p class="section-kicker">为什么做 Folia</p>
            <h2 id="intro-title">Markdown 很轻，法律文档却经常很重。</h2>
          </div>
          <p>
            Folia 重点解决知识工作里的两个断点：复杂 HTML 表格在 Markdown 工具里容易变形，导出 Word 前又很难确认最终纸面效果。它把阅读、轻量编辑、纸张预览和导出放在一个克制的桌面窗口里。
          </p>
        </div>
      </section>

      <section class="section" id="features" aria-labelledby="features-title">
        <div class="section-inner">
          <p class="section-kicker">核心能力</p>
          <h2 id="features-title">为长文档和复杂表格保留耐心。</h2>
          <div class="feature-grid">
            {features.map((feature) => (
              <article class="feature-card">
                <h3>{feature.title}</h3>
                <p>{feature.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section section-workflow" aria-labelledby="workflow-title">
        <div class="section-inner workflow-grid">
          <div>
            <p class="section-kicker">使用流程</p>
            <h2 id="workflow-title">从打开文件到交付结果，只保留必要步骤。</h2>
          </div>
          <ol class="workflow-list">
            {workflow.map((item) => (
              <li>{item}</li>
            ))}
          </ol>
        </div>
      </section>

      <section class="section" id="download" aria-labelledby="download-title">
        <div class="section-inner download-panel">
          <div>
            <p class="section-kicker">下载</p>
            <h2 id="download-title">从 GitHub Releases 获取最新版本。</h2>
            <p>
              当前版本尚未做 Apple Developer 公证。macOS 首次运行如果提示无法验证开发者，请参考 README 中的首次运行说明。
            </p>
          </div>
          <div class="download-actions">
            <a class="button button-primary" href={releasesUrl}>打开下载页</a>
            <a class="button button-secondary" href={`${repoUrl}#readme`} target="_blank" rel="noreferrer">阅读 README</a>
          </div>
          <ul class="download-list" aria-label="安装包选择说明">
            {downloadOptions.map((option) => (
              <li>{option}</li>
            ))}
          </ul>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div>
        <strong>Folia</strong>
        <span>Apache License 2.0</span>
      </div>
      <a href={repoUrl} target="_blank" rel="noreferrer">github.com/cat-xierluo/Folia</a>
    </footer>
  </body>
</html>
